# ============================================================================
# EcoinClass v2 — 환경변수 템플릿
# ============================================================================
# 본 파일을 .env로 복사 후 값 채우기. .env는 .gitignore에 포함됨.
# Cloudflare Pages 프로덕션 시크릿은 `wrangler secret put <KEY>` 로 등록.
# ============================================================================

# ----------------------------------------------------------------------------
# 필수 시크릿 (wrangler secret put 으로 등록)
# ----------------------------------------------------------------------------

# JWT 서명 키 — 32자 이상 랜덤 문자열
# 생성: openssl rand -base64 48
JWT_SECRET=

# ----------------------------------------------------------------------------
# Cloudflare 바인딩 ID (wrangler.toml에 직접 기입)
# ----------------------------------------------------------------------------

# wrangler d1 create ecoinclass-db 실행 후 출력값
D1_DATABASE_ID=

# wrangler kv:namespace create SESSIONS 실행 후 출력값
KV_SESSIONS_ID=
KV_SESSIONS_PREVIEW_ID=

# ----------------------------------------------------------------------------
# 클라이언트(Vite) 환경변수 — VITE_ 접두사 필수
# ----------------------------------------------------------------------------

# 로컬 개발 시 API 베이스 (Pages dev 서버)
VITE_API_BASE_URL=http://localhost:8788/api

# 앱 버전 (이벤트 로그용)
VITE_APP_VERSION=2.0.0

# ----------------------------------------------------------------------------
# 선택: 외부 서비스 (운영 단계)
# ----------------------------------------------------------------------------

# Sentry / 로깅 (선택)
# VITE_SENTRY_DSN=

# ----------------------------------------------------------------------------
# 시크릿 등록 명령 모음
# ----------------------------------------------------------------------------
#
# 로컬: .dev.vars 파일에 KEY=VALUE 형식으로 작성 (gitignore됨)
# 프로덕션: 아래 명령 실행
#
#   wrangler secret put JWT_SECRET
#   wrangler secret put JWT_SECRET --env production
#
# 확인: wrangler secret list
# ============================================================================
